---
// Full-screen hero background that blurs on scroll
---
<section id="hero" class="hero-bg fixed inset-0 z-30">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="https://picsum.photos/seed/romantic-garden-wedding-venue/1920/1080.jpg"
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
    />
    <!-- Gradient overlays for text readability -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-transparent to-black/50"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/10 via-transparent to-black/10"></div>
  </div>

  <!-- Centered text content -->
  <div class="relative z-10 flex flex-col items-center justify-end h-full pb-16 px-4">
    <p class="text-off-white/80 font-body text-sm sm:text-base tracking-[0.35em] uppercase mb-3">
      Netra & Julien
    </p>
    <p class="text-off-white/60 font-body text-xs sm:text-sm tracking-[0.25em]">
      June 6th, 2027
    </p>

    <!-- Scroll indicator -->
    <div class="scroll-indicator mt-14 flex flex-col items-center gap-2">
      <span class="text-off-white/50 text-[10px] sm:text-xs tracking-[0.25em] uppercase font-body">
        Scroll to continue
      </span>
      <svg class="w-5 h-5 text-off-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>