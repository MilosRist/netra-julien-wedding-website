---
// Landing page with couple names and portrait fly-in
---
<section id="landing" class="relative min-h-screen flex flex-col items-center justify-center px-4 py-20 bg-cream">

  <!-- Decorative floral corners -->
  <svg class="floral-corner top-6 left-6 text-gold" viewBox="0 0 80 80" fill="currentColor">
    <path d="M0,0 Q20,12 28,32 Q10,22 0,0Z" />
    <path d="M4,0 Q24,16 34,42 Q14,24 4,0Z" />
    <path d="M14,4 Q32,22 42,48 Q22,30 14,4Z" />
    <circle cx="8" cy="8" r="2.5" />
  </svg>
  <svg class="floral-corner top-6 right-6 text-gold" style="transform: scaleX(-1)" viewBox="0 0 80 80" fill="currentColor">
    <path d="M0,0 Q20,12 28,32 Q10,22 0,0Z" />
    <path d="M4,0 Q24,16 34,42 Q14,24 4,0Z" />
    <path d="M14,4 Q32,22 42,48 Q22,30 14,4Z" />
    <circle cx="8" cy="8" r="2.5" />
  </svg>
  <svg class="floral-corner bottom-6 left-6 text-gold" style="transform: scaleY(-1)" viewBox="0 0 80 80" fill="currentColor">
    <path d="M0,0 Q20,12 28,32 Q10,22 0,0Z" />
    <path d="M4,0 Q24,16 34,42 Q14,24 4,0Z" />
    <path d="M14,4 Q32,22 42,48 Q22,30 14,4Z" />
    <circle cx="8" cy="8" r="2.5" />
  </svg>
  <svg class="floral-corner bottom-6 right-6 text-gold" style="transform: scale(-1)" viewBox="0 0 80 80" fill="currentColor">
    <path d="M0,0 Q20,12 28,32 Q10,22 0,0Z" />
    <path d="M4,0 Q24,16 34,42 Q14,24 4,0Z" />
    <path d="M14,4 Q32,22 42,48 Q22,30 14,4Z" />
    <circle cx="8" cy="8" r="2.5" />
  </svg>

  <!-- Names header -->
  <div class="text-center mb-14 sm:mb-16 fade-up">
    <p class="font-body text-brown-light text-xs sm:text-sm tracking-[0.35em] uppercase mb-5">
      Together with their families
    </p>
    <h1 class="font-display text-5xl sm:text-7xl lg:text-[5.5rem] text-brown-dark font-medium tracking-tight leading-none mb-1">
      Netra
    </h1>
    <p class="font-display text-2xl sm:text-3xl text-red-wine italic my-2">&</p>
    <h1 class="font-display text-5xl sm:text-7xl lg:text-[5.5rem] text-brown-dark font-medium tracking-tight leading-none">
      Julien
    </h1>

    <!-- Ornamental star divider -->
    <div class="ornament-divider mt-8">
      <div class="ornament-line"></div>
      <svg class="w-3.5 h-3.5 text-gold flex-shrink-0" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8,0 L10,6 L16,8 L10,10 L8,16 L6,10 L0,8 L6,6Z" />
      </svg>
      <div class="ornament-line"></div>
    </div>

    <p class="font-body text-lg sm:text-xl text-brown-medium mt-6 tracking-[0.18em]">
      June 6th, 2027
    </p>
    <p class="font-body text-sm text-brown-light mt-2 tracking-[0.12em]">
      The Garden Estate &middot; Tuscany, Italy
    </p>
  </div>

  <!-- Portraits row -->
  <div class="flex flex-col sm:flex-row items-center gap-10 sm:gap-16 lg:gap-24 w-full max-w-3xl justify-center">
    <!-- Netra's portrait -->
    <div class="portrait-left" id="portrait-netra">
      <div class="portrait-frame rounded-sm">
        <div class="relative overflow-hidden rounded-sm" style="aspect-ratio: 3/4; width: 280px; max-width: 70vw;">
          <img
            src="https://picsum.photos/seed/netra-bride-elegant/400/533.jpg"
            alt="Netra"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
      <p class="text-center font-display text-xl text-brown-dark mt-4 tracking-wide">Netra</p>
    </div>

    <!-- Julien's portrait -->
    <div class="portrait-right" id="portrait-julien">
      <div class="portrait-frame rounded-sm">
        <div class="relative overflow-hidden rounded-sm" style="aspect-ratio: 3/4; width: 280px; max-width: 70vw;">
          <img
            src="https://picsum.photos/seed/julien-groom-elegant/400/533.jpg"
            alt="Julien"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
      <p class="text-center font-display text-xl text-brown-dark mt-4 tracking-wide">Julien</p>
    </div>
  </div>
</section>